# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# MongoDB connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Secret key used to sign JWT tokens — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Port the server listens on (defaults to 3000)
PORT=3000

# Allowed CORS origin for the frontend (e.g. https://your-username.github.io)
# Omit to allow all origins (not recommended for production)
CORS_ORIGIN=https://your-username.github.io
